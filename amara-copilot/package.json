{
  "name": "amara-copilot",
  "displayName": "Amara Copilot",
  "description": "Asistente de IA con contexto del archivo o carpeta abierta",
  "version": "0.0.1",
  "publisher": "randomanimationa",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:amara-copilot.chatView",
    "onCommand:amara-copilot.openPanel",
    "onCommand:amara-copilot.openSettings"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "amara-copilot.openPanel",
        "title": "Abrir panel de Amara Copilot"
      },
      {
        "command": "amara-copilot.openSettings",
        "title": "Abrir configuración de Amara Copilot"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "amara-copilot-view-container",
          "title": "Amara Copilot",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "amara-copilot-view-container": [
        {
          "id": "amara-copilot.chatView",
          "name": "Asistente",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Amara Copilot",
      "properties": {
        "amara-copilot.apiEndpoint": {
          "type": "string",
          "default": "http://localhost:1234/v1/chat/completions",
          "description": "Endpoint de la API de LM Studio (u otra compatible con OpenAI)."
        },
        "amara-copilot.modelName": {
          "type": "string",
          "default": "local-model",
          "description": "Nombre del modelo a usar en LM Studio."
        },
        "amara-copilot.apiKey": {
          "type": "string",
          "default": "not-needed",
          "description": "Clave de API (si tu servidor la requiere)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "npm run bundle",
    "watch": "npm run bundle -- --watch",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./dist/test/runTest.js"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "esbuild": "^0.21.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RandomAnimationa/Amara-copilot"
  }
}