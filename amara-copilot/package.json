{
  "name": "amara-copilot",
  "displayName": "Amara Copilot",
  "description": "Asistente de IA con contexto del archivo o carpeta abierta. Compatible con LM Studio.",
  "version": "0.1.0",
  "publisher": "RandomAnimations",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "AI"],
  "activationEvents": [
    "onView:amara-copilot.chatView",
    "onCommand:amara-copilot.openPanel",
    "onCommand:amara-copilot.openAIConfig"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "amara-copilot.openPanel", "title": "Abrir panel de Amara Copilot" },
      { "command": "amara-copilot.openAIConfig", "title": "Abrir configuración de IA" }
    ],
    "viewsContainers": {
      "activitybar": [{
        "id": "amara-copilot-view-container",
        "title": "Amara Copilot",
        "icon": "media/icon.png"
      }]
    },
    "views": {
      "amara-copilot-view-container": [{
        "id": "amara-copilot.chatView",
        "name": "Asistente",
        "type": "webview"
      }]
    },
    "configuration": {
      "title": "Amara Copilot",
      "properties": {
        "amara-copilot.apiEndpoint": {
          "type": "string",
          "default": "http://localhost:1234/v1/chat/completions",
          "description": "Endpoint de la API de LM Studio"
        },
        "amara-copilot.modelName": {
          "type": "string",
          "default": "local-model",
          "description": "Nombre del modelo"
        },
        "amara-copilot.apiKey": {
          "type": "string",
          "default": "not-needed",
          "description": "API Key (opcional)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/mocha": "^10.0.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RandomAnimationa/Amara-copilot"
  }
}