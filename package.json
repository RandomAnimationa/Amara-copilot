{
  "name": "cudium-amara-extension",
  "displayName": "Cudium Amara Extension",
  "description": "Extensión tipo Copilot para Codium usando Amara (LM Studio API)",
  "version": "0.2.0",
  "publisher": "randomanimationa",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "amaraSidebar",
          "title": "Amara Copilot",
          "icon": "resources/icon.png"
        }
      ]
    },
    "views": {
      "amaraSidebar": [
        {
          "id": "amaraChat",
          "name": "Chat con Amara"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "package": "vsce package"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "typescript": "^5.3.3"
  }
}
